{
  "name": "create-smart-api",
  "version": "4.3.9",
  "description": "CLI tool to quickly generate production-ready Node.js REST APIs with CRUD, authentication, validation, testing, and microservices support",
  "preferGlobal": true,
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "bin": {
    "create-smart-api": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "ts-node src/bin/cli.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "node -e \"if(!process.env.CI){console.error('Use GitHub Actions to publish');process.exit(1)}\""
  },
  "keywords": [
    "create-smart-api",
    "nodejs cli",
    "api generator",
    "rest api generator",
    "express generator",
    "backend generator",
    "node boilerplate",
    "api scaffolding",
    "code generator",
    "crud api",
    "authentication",
    "jwt auth",
    "zod validation",
    "typescript api",
    "microservices",
    "swagger api",
    "fastify",
    "cli tool",
    "backend cli",
    "developer tools"
  ],
  "author": {
    "name": "Chirag Chauhan",
    "url": "https://github.com/cvchauhan"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/cvchauhan"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "fastest-levenshtein": "^1.0.16",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cvchauhan/create-smart-api"
  },
  "bugs": {
    "url": "https://github.com/cvchauhan/create-smart-api/issues"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/prompts": "^2.4.9",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "homepage": "https://github.com/cvchauhan/create-smart-api#readme",
  "publishConfig": {
    "provenance": true
  }
}
