{
  "name": "create-smart-api",
  "version": "3.0.1",
  "description": "CLI to generate production-ready Node.js APIs with CRUD, auth, validation, testing and microservices",
  "type": "module",
  "preferGlobal": true,
  "bin": {
    "create-smart-api": "./bin/cli.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "keywords": [
    "nodejs",
    "cli",
    "api-generator",
    "express",
    "crud",
    "microservices",
    "jest",
    "backend"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4",
    "inquirer": "^13.3.2",
    "jsonwebtoken": "^9.0.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cvchauhan/create-smart-api"
  },
  "bugs": {
    "url": "https://github.com/cvchauhan/create-smart-api/issues"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0"
  }
}
