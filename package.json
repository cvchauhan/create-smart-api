{
  "name": "create-smart-api",
  "version": "4.0.1",
  "description": "CLI to generate production-ready Node.js APIs with CRUD, auth, validation, testing and microservices",
  "preferGlobal": true,
  "main": "dist/bin/cli.js",
  "types": "dist/bin/cli.d.ts",
  "bin": {
    "create-smart-api": "dist/bin/cli.js"
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "build": "tsc",
    "dev": "ts-node src/bin/cli.ts",
    "dev:test": "npm run build && npm link",
    "publish": "npm run build && npm publish",
    "patch": "npm run build && npm version patch && npm publish",
    "minor": "npm run build && npm version minor && npm publish",
    "major": "npm run build && npm version major && npm publish"
  },
  "keywords": [
    "create-smart-api",
    "smart-api",
    "api",
    "generator",
    "codegen",
    "cli-tool",
    "code-generator",
    "scaffolding",
    "modules",
    "authentication",
    "crud",
    "validation",
    "testing",
    "typescript",
    "zod",
    "jsonwebtoken",
    "bcrypt",
    "fs-extra",
    "inquirer",
    "nodejs",
    "cli",
    "api-generator",
    "express",
    "crud",
    "microservices",
    "jest",
    "backend",
    "javascript",
    "swagger",
    "fastify"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "fastest-levenshtein": "^1.0.16",
    "fs-extra": "^11.3.4",
    "inquirer": "^13.3.2",
    "jsonwebtoken": "^9.0.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cvchauhan/create-smart-api"
  },
  "bugs": {
    "url": "https://github.com/cvchauhan/create-smart-api/issues"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
